{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "blocks": [
        {
            "alignment": "left",
            "type": "prompt",
            "segments": [
                {
                    "type": "os",
                    "style": "plain",
                    "foreground": "#A8D8E8",
                    "template": "[{{ if .WSL }}WSL {{ end }}{{.Icon}}]",
                    "options": {
                        "windows": "Windows"
                    }
                },
                {
                    "type": "session",
                    "style": "plain",
                    "foreground": "#F0A8D8",
                    "template": "[{{ .UserName }}@{{ .HostName }}]"
                },
                {
                    "type": "path",
                    "style": "plain",
                    "foreground": "#B8E6B8",
                    "template": "[{{ .Path }}]",
                    "options": {
                        "style": "agnoster_short"
                    }
                },
                {
                    "type": "git",
                    "style": "plain",
                    "foreground": "#FFD4B4",
                    "template": "[{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}]",
                    "options": {
                        "fetch_status": true,
						"fetch_push_status": true,
                        "fetch_upstream_icon": true
                    }
                }
            ]
        },
        {
            "alignment": "left",
            "type": "prompt",
            "newline": true,
            "segments": [
                {
                    "type": "shell",
                    "style": "plain",
                    "foreground": "#E8C4A8",
                    "template": "[{{ .Name }}]>"
                }
            ]
        }
    ],
    "final_space": true,
    "version": 4
}